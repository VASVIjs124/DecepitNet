# DECEPTINET Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deceptinet
POSTGRES_USER=deceptinet_user
POSTGRES_PASSWORD=changeme_strong_password

# MongoDB (for malware artifacts)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=deceptinet_artifacts
MONGODB_USER=deceptinet_mongo
MONGODB_PASSWORD=changeme_strong_password

# Redis (caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_strong_password
REDIS_DB=0

# =============================================================================
# MESSAGE QUEUE - KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=honeypot-events
KAFKA_TOPIC_PREDICTIONS=ml-predictions
KAFKA_TOPIC_ALERTS=security-alerts
KAFKA_GROUP_ID=deceptinet-consumer

# =============================================================================
# ELASTICSEARCH (ELK STACK)
# =============================================================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme_strong_password
ELASTICSEARCH_INDEX_EVENTS=deceptinet-events
ELASTICSEARCH_INDEX_PREDICTIONS=deceptinet-predictions

# =============================================================================
# THREAT INTELLIGENCE PLATFORMS
# =============================================================================
# MISP
MISP_URL=https://misp.your-domain.com
MISP_API_KEY=your_misp_api_key_here
MISP_VERIFY_SSL=true

# OpenCTI
OPENCTI_URL=https://opencti.your-domain.com
OPENCTI_API_KEY=your_opencti_api_key_here
OPENCTI_VERIFY_SSL=true

# =============================================================================
# DECEPTION ENGINE API
# =============================================================================
DECEPTION_ENGINE_HOST=0.0.0.0
DECEPTION_ENGINE_PORT=8000
DECEPTION_ENGINE_WORKERS=4
DECEPTION_ENGINE_RELOAD=false

# API Security
API_SECRET_KEY=changeme_generate_secure_random_key_here
API_CORS_ORIGINS=http://localhost:3000,https://dashboard.your-domain.com
API_RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# ML/AI CONFIGURATION
# =============================================================================
ML_MODEL_PATH=./models
ML_BATCH_SIZE=50
ML_BATCH_TIMEOUT=5.0
ML_INFERENCE_THRESHOLD=0.7
ML_ENABLE_GPU=false

# Reinforcement Learning
RL_TRAINING_TIMESTEPS=100000
RL_SAVE_INTERVAL=10000
RL_ALGORITHM=PPO
RL_LEARNING_RATE=0.0003

# =============================================================================
# HONEYPOT CONFIGURATION
# =============================================================================
# Cowrie (SSH/Telnet)
COWRIE_HOST=0.0.0.0
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2323
COWRIE_API_URL=http://localhost:8001

# Dionaea (Malware)
DIONAEA_HOST=0.0.0.0
DIONAEA_API_URL=http://localhost:8002

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
METRICS_EXPORT_INTERVAL=15

# Grafana
GRAFANA_HOST=localhost
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password

# Application Insights / Telemetry
ENABLE_TELEMETRY=true
TELEMETRY_EXPORT_INTERVAL=60

# =============================================================================
# REACT DASHBOARD
# =============================================================================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_ENVIRONMENT=production

# =============================================================================
# KUBERNETES / DOCKER
# =============================================================================
NAMESPACE=deceptinet
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
REPLICAS=3

# Resource Limits
CPU_REQUEST=500m
CPU_LIMIT=2000m
MEMORY_REQUEST=1Gi
MEMORY_LIMIT=4Gi

# =============================================================================
# SECURITY
# =============================================================================
# Encryption
ENCRYPTION_KEY=changeme_generate_32_byte_key_here
JWT_SECRET=changeme_generate_jwt_secret_here
JWT_EXPIRATION_HOURS=24

# TLS/SSL
TLS_ENABLED=true
TLS_CERT_PATH=/etc/ssl/certs/deceptinet.crt
TLS_KEY_PATH=/etc/ssl/private/deceptinet.key

# =============================================================================
# CLOUD PROVIDER (AWS/Azure/GCP)
# =============================================================================
# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_BACKUPS=deceptinet-backups
S3_BUCKET_MODELS=deceptinet-models

# Azure (uncomment if using Azure)
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_RESOURCE_GROUP=deceptinet-rg
# AZURE_STORAGE_ACCOUNT=deceptinetstorage
# AZURE_STORAGE_KEY=your_storage_key

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3://deceptinet-backups

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_ML_ENABLED=true
FEATURE_RL_ENABLED=true
FEATURE_TI_ENRICHMENT=true
FEATURE_AUTO_ADAPTATION=true
FEATURE_DASHBOARD_ENABLED=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
MAX_WORKERS=8
ASYNC_POOL_SIZE=100
CONNECTION_TIMEOUT=30
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# =============================================================================
# LOGGING
# =============================================================================
LOG_FILE=./logs/deceptinet.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10
LOG_FORMAT=json
LOG_INCLUDE_TIMESTAMP=true
